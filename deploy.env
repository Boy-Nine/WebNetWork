# 全局部署配置：本地/线上只改这个文件，然后重新执行 ./scripts/apply-config.sh
# 本机局域网 IP 可用：ipconfig getifaddr en0  或  ifconfig | grep 'inet '

# 对外访问地址：本地可填 http://0.0.0.0:3088 / http://0.0.0.0:3090，
# 局域网调试建议改成 http://你的本机IP:3088 / http://你的本机IP:3090，
# 线上建议改成 https://api.example.com / https://capture.example.com。
PUBLIC_API_BASE=http://0.0.0.0:3088
PUBLIC_WEB_BASE=http://0.0.0.0:3090

# 宿主机监听端口
BACKEND_PORT=3088
WEB_PORT=3090

# 后端与数据库配置
POSTGRES_DB=webgrabber
POSTGRES_USER=webgrabber
POSTGRES_PASSWORD=webgrabber
JWT_SECRET_KEY=please-change-this-secret-at-least-32-bytes
JWT_EXPIRE_MINUTES=10080
MAX_HTML_SIZE_MB=5
MAX_RESPONSE_BODY_MB=2
MAX_UPLOAD_BYTES=12582912
CORS_ORIGINS=*
